# If several keys are set, OpenRouter is used first unless you force a provider:
# LLM_PROVIDER=openrouter | gemini | openai

# OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Google AI Studio / Gemini (https://aistudio.google.com/apikey)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI (or OpenRouter via base URL)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
